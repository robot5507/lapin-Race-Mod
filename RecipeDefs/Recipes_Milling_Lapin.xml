<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <RecipeDef>
    <defName>MillLapinWheat</defName>
    <label>밀 제분하기</label>
    <description>밀알을 맷돌로 갈아서 밀가루를 만든다.</description>
    <jobString>밀을 제분하는 중</jobString>

    <workAmount>100</workAmount>
    <workSpeedStat>CookSpeed</workSpeedStat>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>RawLapinWheat</li>
          </thingDefs>
        </filter>
        <count>3</count>
      </li>
    </ingredients>

    <products>
      <RawLapinFlour>1</RawLapinFlour>
    </products>

    <recipeUsers>
      <li>LapinMillstone</li>
    </recipeUsers>

    <allowMixingIngredients>false</allowMixingIngredients>
    <workSkill>Cooking</workSkill>
  </RecipeDef>

</Defs>