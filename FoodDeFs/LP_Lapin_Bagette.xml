    <smeltable>false</smeltable>
    <graphicData>
      <texPath>Things/Item/LP_Lapin_Bagette</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
      <drawSize>1.0</drawSize>
    </graphicData>

    <socialPropernessMatters>true</socialPropernessMatters>

    <statBases>
      <Mass>0.6</Mass>
      <MarketValue>8</MarketValue>
      <MeleeWeapon_DamageMultiplier>1.0</MeleeWeapon_DamageMultiplier>
      <MeleeWeapon_CooldownMultiplier>1.1</MeleeWeapon_CooldownMultiplier>
      <Nutrition>1.0</Nutrition>
    </statBases>

    <equippedStatOffsets>
      <MeleeWeapon_DamageMultiplier>1.0</MeleeWeapon_DamageMultiplier>
    </equippedStatOffsets>

    <tools>
      <li>
        <label>빵 몸통</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>13</power>
