	<RulePackDef>
		<defName>NamerFaction_LapinRenegades</defName>
		<include>
			<li>EmpireNameUtility</li>
		</include>
		<rulePack>
			<rulesStrings>
				<li>r_name(p=2)->[empire_Renegades] of [ofThing]</li>
				<li>r_name->The Lapin Renegades</li>
				<li>r_name->The Lapin [empire]</li>

			

				<li>ofThing(p=3)->[WordImperial]</li>
				<li>ofThing->the Lapin_Renegades</li>
			</rulesStrings>
		</rulePack>
	</RulePackDef>

