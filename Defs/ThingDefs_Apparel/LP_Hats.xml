  <ThingCategoryDef>
    <defName>LP_Headgear</defName>
    <label>lapin headgear</label>
    <parent>Headgear</parent>
  </ThingCategoryDef>

  <ThingDef Class="LapinRace.CustomThingDef" Name="LP_HatMakeableBase" ParentName="LP_ApparelMakeableBase" Abstract="True">
    <thingCategories>
      <li>LP_Headgear</li>
    </thingCategories>
    <apparel>
      <renderSkipFlags>
        <li>None</li>
      </renderSkipFlags>
    </apparel>
  </ThingDef>


  <ThingDef Class="LapinRace.CustomThingDef" ParentName="LP_HatMakeableBase">
    <defName>LP_Hat_Grenadier</defName>
    <label>라핀 척탄병 모자</label>
    <description>라핀 제국 척탄병이 착용하는 전용 군모.</description>

    <thingClass>Apparel</thingClass>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <ArmorRating_Sharp>0.12</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.08</ArmorRating_Blunt>
      <Mass>0.4</Mass>
      <MarketValue>60</MarketValue>
    </statBases>
    <apparel>

      <!-- 머리 장착 -->
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>

      <!-- 헤드 레이어 -->
      <layers>
        <li>Overhead</li>
      </layers>

      <defaultOutfitTags>
        <li>LP_Soldier</li>
      </defaultOutfitTags>
      <tags>
        <li>LP_Apparel</li>
        <li>BasicApparel</li>
      </tags>

      <wornGraphicPath>Apparel/LP_GrenadierHat</wornGraphicPath>

    </apparel>

    <!-- 그래픽 -->
    <graphicData>
      <texPath>Apparel/LP_GrenadierHat</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>

    <!-- 제작 재료 -->
    <costList>
      <Cloth>30</Cloth>
    </costList>

    <!-- 태그 -->

  </ThingDef>

