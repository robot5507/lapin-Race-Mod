<?xml version="1.0" encoding="utf-8" ?>
<Defs>
<ThingDef Class="LapinRace.CustomThingDef" ParentName="LP_ApparelMakeableBase">
  <defName>LP_TacticalShieldBelt</defName>
  <label>라핀 전술 보호막 벨트</label>
  <description>라핀 특수부대가 사용하는 전술 보호막 벨트입니다.어떤 원리로 만드는지 알수 없습니다. 에너지가 0이되면 파괴됩니다.</description>
<thingClass>Apparel</thingClass>
<recipeMaker Inherit="False" />  
  <stuffCategories Inherit="False" />
   <costList>
      <Cloth>60</Cloth>
    </costList>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/ShieldBelt/ShieldBelt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
   <tickerType>Normal</tickerType>
    <statBases>
      <Mass>3</Mass>
      <Flammability>0</Flammability>
      <EnergyShieldRechargeRate>0.013</EnergyShieldRechargeRate>
      <EnergyShieldEnergyMax>4.0</EnergyShieldEnergyMax>
    </statBases>
    <apparel>
      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <defaultOutfitTags>
      <li>LP_TacticalShieldBelt</li>
      </defaultOutfitTags>
      <tags>
        <li>LP_TacticalShieldBelt</li>
      </tags>
    </apparel>
    <comps>
      <li Class="CompProperties_Shield">
        <startingTicksToReset>36000</startingTicksToReset><!-- 10 mins -->
        <minDrawSize>2.5</minDrawSize>
        <maxDrawSize>2.8</maxDrawSize>
        <energyLossPerDamage>0.01</energyLossPerDamage>
        <energyOnReset>4.0</energyOnReset>
        <blocksRangedWeapons>false</blocksRangedWeapons>
      </li>
      <li Class="LapinRace.CompProperties_DestroyWhenShieldEmpty" />
    </comps>
    <allowedArchonexusCount>1</allowedArchonexusCount>
  </ThingDef>
</Defs>