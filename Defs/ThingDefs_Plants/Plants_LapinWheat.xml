<?xml version="1.0" encoding="utf-8"?>
<Defs>

 
  <ThingDef ParentName="PlantBase">
    <defName>PlantLapinWheat</defName>
    <label>라핀 밀</label>
    <description>바게트를 만들기 위한 밀. 성장 속도가 빠르고 수확량이 괜찮다.</description>
    
    <graphicData>
      <texPath>Things/Plant/LapinWheat</texPath>
      <graphicClass>Graphic_Random</graphicClass>  
      <drawSize>1.0</drawSize>
    </graphicData>
    
    <plant>
      <immatureGraphicPath>Things/Plant/LapinWheat_Seedling</immatureGraphicPath>
      <dieIfLeafless>true</dieIfLeafless>
      <maxMeshCount>4</maxMeshCount>
      <harvestAfterGrowth>0.50</harvestAfterGrowth>
      <growDays>6.5</growDays>
      <harvestWork>180</harvestWork>
      <harvestYield>20</harvestYield>
      <harvestedThingDef>RawLapinWheat</harvestedThingDef>
      <harvestTag>Standard</harvestTag>
      <sowTags>
        <li>Ground</li>
        <li>Hydroponic</li>
      </sowTags>
      <topWindExposure>0.1</topWindExposure>
      <visualSizeRange>0.5~0.8</visualSizeRange>
      <wildOrder>2</wildOrder>
      <purpose>Food</purpose>
      <humanFoodPlant>true</humanFoodPlant>
      </plant>
    <statBases>
      <Beauty>-1</Beauty>
      <Nutrition>0.85</Nutrition>
    </statBases>
    
  </ThingDef>

</Defs>