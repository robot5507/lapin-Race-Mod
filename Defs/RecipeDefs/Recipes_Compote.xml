<?xml version="1.0" encoding="utf-8"?>
<Defs>

<RecipeDef ParentName="CookMealBase">
  <defName>Make_LP_Compote</defName>
  <label>라핀 컴포트 만들기</label>
  <jobString>라핀 컴포트 잼을 만든다.</jobString>

  <workAmount>700</workAmount>
  <workSpeedStat>CookSpeed</workSpeedStat>
  <effectWorking>Cook</effectWorking>
  <soundWorking>Recipe_CookMeal</soundWorking>

  <recipeUsers>
    <li>ElectricStove</li>
    <li>FueledStove</li>
  </recipeUsers>

  <ingredients>
    <li>
      <filter>
        <thingDefs>
         <li>RawBerries</li>
        </thingDefs>
      </filter>
      <count>15</count>
    </li>
    <li>
      <filter>
        <thingDefs>
          <li>LP_StrawberryJuice</li>
        </thingDefs>
      </filter>
      <count>1</count>
    </li>

    
  </ingredients>

  <fixedIngredientFilter>
    <thingDefs>
      <li>RawBerries</li>
    </thingDefs>
    <thingDefs>
      <li>LP_StrawberryJuice</li>
    </thingDefs>
  </fixedIngredientFilter>

  <products>
    <LP_Compote>1</LP_Compote>
  </products>
  <researchPrerequisite>LP_LapinCookingKnowhow</researchPrerequisite>
</RecipeDef>


</Defs>