<?xml version="1.0" encoding="utf-8"?>
<Defs>

   <RecipeDef ParentName="SurgeryInstallBodyPartArtificialBase">
    <defName>InstallBaguetteArm</defName>
    <label>바게트 팔 이식 수술</label>
    <label>바게트 팔 이식</label>
    <description>림의 팔을 절단하고 바게트로 대체한다. 맛있는 팔이 될 것이다.</description>
    <descriptionHyperlinks><ThingDef>LP_Lapin_Bagette</ThingDef></descriptionHyperlinks>
    <jobString>바게트 팔을 이식하는 중</jobString>
    <uiIconThing>LP_Lapin_Bagette</uiIconThing>
     <workerClass>LapinBaguette.Recipe_InstallBaguetteArm</workerClass>

    <workAmount>1800</workAmount>         
    <workSpeedStat>MedicalOperationSpeed</workSpeedStat>

    <skillRequirements>
      <Medicine>5</Medicine>               
    </skillRequirements>

    
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>LP_Lapin_Bagette</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>

    
    <appliedOnFixedBodyParts>
      <li>Shoulder</li>
    </appliedOnFixedBodyParts>

    
    <addsHediff>BaguetteArm</addsHediff>

    
    <removesHediff>MissingBodyPart</removesHediff>

    <recipeUsers>
      <li>Human</li>                       
    </recipeUsers>

    <isViolation>true</isViolation>
    <deathOnFailedSurgeryChance>0.05</deathOnFailedSurgeryChance>
    <researchPrerequisite>LP_LapinBagutteSurgery</researchPrerequisite>
  </RecipeDef>

  <RecipeDef ParentName="SurgeryInstallBodyPartArtificialBase">
    <defName>InstallBaguetteLeg</defName>
    <label>바게트 발 이식</label>
    <description>림의 발을 절단하고 바게트로 대체한다.</description>
    <descriptionHyperlinks><ThingDef>LP_Lapin_Bagette</ThingDef></descriptionHyperlinks>
    <jobString>바게트 발을 이식하는 중</jobString>
    <uiIconThing>LP_Lapin_Bagette</uiIconThing>
    <workerClass>LapinBaguette.Recipe_InstallBaguetteLeg</workerClass>
    <workAmount>1800</workAmount>          
    <workSpeedStat>MedicalOperationSpeed</workSpeedStat>

    <skillRequirements>
      <Medicine>5</Medicine>              
    </skillRequirements>

   
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>LP_Lapin_Bagette</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>

   
    <appliedOnFixedBodyParts>
      <li>Leg</li>
    </appliedOnFixedBodyParts>

    
    <addsHediff>BaguetteLeg</addsHediff>

    
    <removesHediff>MissingBodyPart</removesHediff>

    <recipeUsers>
      <li>Human</li>                       
    </recipeUsers>

    <isViolation>true</isViolation>
    <deathOnFailedSurgeryChance>0.05</deathOnFailedSurgeryChance>
    <researchPrerequisite>LP_LapinBagutteSurgery</researchPrerequisite>
  </RecipeDef>

</Defs>