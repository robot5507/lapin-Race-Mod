  </recipeUsers>

  <ingredients>
    <li>
      <filter>
        <thingDefs>
          <li>LP_Lapin_Bagette</li>
        </thingDefs>
      </filter>
      <count>2</count>
    </li>

    <li>
      <filter>
        <categories>
          <li>MeatRaw</li>
        </categories>
      </filter>
      <count>10</count>
    </li>
  </ingredients>

  <fixedIngredientFilter>
    <thingDefs>
      <li>LP_Lapin_Bagette</li>
    </thingDefs>
    <categories>
      <li>MeatRaw</li>
    </categories>
  </fixedIngredientFilter>

  <products>
    <LP_JambonBeurre>1</LP_JambonBeurre>
  </products>
