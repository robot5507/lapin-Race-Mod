<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef ParentName="AddedBodyPartBase">
  <defName>BaguetteArm</defName>
  <label>팔이 바게트</label>
  <labelNoun>팔이바게트</labelNoun>
  <description>이 림의 팔이 바게트로 대체되었다.</description>
  <hediffClass>Hediff_AddedPart</hediffClass>
  <defaultLabelColor>(0.9, 0.7, 0.4)</defaultLabelColor>

  <addedPartProps>
    <solid>true</solid>
    <partEfficiency>1.0</partEfficiency>
    <betterThanNatural>false</betterThanNatural>
  </addedPartProps>

  <spawnThingOnRemoved>LP_Lapin_Bagette</spawnThingOnRemoved>

  <comps>
  <li Class="LapinBaguette.HediffCompProperties_BaguetteQuality" />
  <li Class="HediffCompProperties_VerbGiver">
    <verbs>
      <li>
        <verbClass>Verb_MeleeAttackDamage</verbClass>
        <label>바게트 팔로 후려치기</label>
        <range>1.42</range>
        <warmupTime>0</warmupTime>
        <defaultCooldownTime>1.6</defaultCooldownTime>
        <meleeDamageBaseAmount>12</meleeDamageBaseAmount>
        <meleeDamageDef>Blunt</meleeDamageDef>
        <soundCast>Pawn_Melee_Punch_HitPawn</soundCast>
      </li>
    </verbs>
  </li>
</comps>
</HediffDef>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>BaguetteLeg</defName>
    <label>발이 바게트</label>
    <labelNoun>발이바게트</labelNoun>
    <description>이 림의 발이 바게트로 대체되었다.</description>
    <hediffClass>Hediff_AddedPart</hediffClass>
    <defaultLabelColor>(0.9, 0.7, 0.4)</defaultLabelColor>

    <addedPartProps>
      <solid>true</solid>
      <partEfficiency>0.85</partEfficiency>
      <betterThanNatural>false</betterThanNatural>
    </addedPartProps>

    <spawnThingOnRemoved>LP_Lapin_Bagette</spawnThingOnRemoved>
  </HediffDef>

  <HediffDef>
    <defName>BaguetteArmHit</defName>
    <label>바게트 팔로 때림</label>
    <description>맛있는 바게트 팔에 세게 후려맞았다.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>600</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>

</Defs>