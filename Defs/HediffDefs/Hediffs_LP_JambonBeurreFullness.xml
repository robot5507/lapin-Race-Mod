<?xml version="1.0" encoding="utf-8"?>
<Defs>

<HediffDef>
  <defName>LP_JambonBeurreFullness</defName>
  <label>든든한 잠봉뵈르</label>
  <description>라핀식 잠봉뵈르를 먹어 오랫동안 배가 든든합니다.</description>
  <hediffClass>HediffWithComps</hediffClass>
  <isBad>false</isBad>

  <comps>
    <li Class="HediffCompProperties_Disappears">
      <disappearsAfterTicks>25000</disappearsAfterTicks>
    </li>

    <li Class="LapinRace.HediffCompProperties_ReduceHungerFall">
      <hungerFallMultiplier>0.01</hungerFallMultiplier>
    </li>
  </comps>

  <stages>
    <li>
      <label>든든함</label>
    </li>
  </stages>
</HediffDef>

</Defs>